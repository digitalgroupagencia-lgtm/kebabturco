# Variáveis públicas do frontend (sem Google Maps — integração removida)
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Chave PUBLICÁVEL Stripe live (pk_live_...) — fallback também em src/lib/stripePublishableKey.ts
VITE_STRIPE_PUBLISHABLE_KEY=

# Chave PUBLICÁVEL Stripe teste — NÃO usar Segredos Lovable.
# Colar em config/stripe.public.env (recomendado) ou em KEBAB_TURCO_STRIPE_PUBLISHABLE_TEST no código.
# VITE_STRIPE_PUBLISHABLE_KEY_TEST=

# Segredos (só servidor — Lovable Cloud → Segredos):
# STRIPE_SECRET_KEY          — sk_live (produção)
# STRIPE_SECRET_KEY_TEST     — sk_test (modo teste enquanto plataforma pendente)
# STRIPE_WEBHOOK_SECRET      — segredo webhook endpoint live
# STRIPE_WEBHOOK_SECRET_TEST — segredo webhook endpoint teste
# STRIPE_WEBHOOK_SECRET_TEST_MINIMAL — segredo webhook teste alternativo (minimal)
#
# ── Web Push (alertas equipa + cliente) ──
# Gerar: npm run generate:vapid
# VITE_VAPID_PUBLIC_KEY=          → Lovable / frontend (público)
# VAPID_PUBLIC_KEY=               → Supabase Edge secret (send-push-notification)
# VAPID_PRIVATE_KEY=              → Supabase Edge secret (send-push-notification)
# STAFF_PUSH_INTERNAL_SECRET=     → Supabase Edge secret + SQL platform_push_config.staff_push_secret
#
# ── Push nativo Android/iOS (app Capacitor) ──
# Firebase → kebab-turco-gandia → Conta de serviço → JSON
# FCM_SERVICE_ACCOUNT_JSON=       → Supabase Edge secret (send-push-notification)
# Ver supabase/scripts/LOVABLE_PASSO_FCM_PUSH.txt
# Login Google equipa: por defeito usa Lovable (funciona sem configurar Supabase).
# Para login directo Google/Supabase (sem ecrã Lovable), configure Google em
# Supabase → Authentication → Providers e active:
# VITE_STAFF_GOOGLE_VIA_SUPABASE=true
#
# ── Android TWA (Play Store) ──
# VITE_ANDROID_PACKAGE_NAME=
# VITE_ANDROID_SHA256_FINGERPRINT=
# Gerar assetlinks: npm run generate:assetlinks
