# Variáveis públicas do frontend (sem Google Maps — integração removida)
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Chave PUBLICÁVEL Stripe live (pk_live_...) — variáveis de ambiente Lovable, NÃO Segredos.
# O projecto Kebab Turco também inclui fallback live em src/lib/stripePublishableKey.ts
VITE_STRIPE_PUBLISHABLE_KEY=

# Chave PUBLICÁVEL Stripe teste (pk_test_...) — necessária enquanto plataforma aguarda verificação
VITE_STRIPE_PUBLISHABLE_KEY_TEST=

# Segredos (só servidor — Lovable Cloud → Segredos):
# STRIPE_SECRET_KEY          — sk_live (produção)
# STRIPE_SECRET_KEY_TEST     — sk_test (modo teste enquanto plataforma pendente)
# STRIPE_WEBHOOK_SECRET      — segredo webhook endpoint live
# STRIPE_WEBHOOK_SECRET_TEST — segredo webhook endpoint teste (mesma URL, modo teste na Stripe)
# VITE_VAPID_PUBLIC_KEY=
