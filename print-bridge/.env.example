# ============================================================
# Kebab Print Bridge — configuração por loja/unidade
# Copie este ficheiro para .env e preencha os valores.
# Uma instância por loja — cada uma com STORE_ID diferente.
# ============================================================

# URL do projecto Supabase (Settings → API → Project URL)
SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Chave service_role (Settings → API → service_role — NUNCA partilhar)
SUPABASE_SERVICE_ROLE_KEY=

# UUID da unidade/loja (Admin → Impressora → banner "A configurar")
STORE_ID=

# Impressora térmica na rede local (LAN)
PRINTER_IP=192.168.1.200
PRINTER_PORT=9100

# Aliases legados (opcional — use PRINTER_IP / PRINTER_PORT acima)
# DEFAULT_PRINTER_IP=192.168.1.200
# DEFAULT_PRINTER_PORT=9100

# Fallback legado — não recomendado após hardening de segurança
# SUPABASE_ANON_KEY=
