# Configuração do Visit Print Bridge (Mac) — Lovable Cloud
# Copie para: ~/.kebab-visit-print.env

SUPABASE_URL=https://kvpssbhclafoymhecmuk.supabase.co

# Chave pública (anon) — Lovable Cloud ou Supabase → API → anon
SUPABASE_ANON_KEY=cole_a_chave_publica_anon

# Mesmo valor em Lovable → Cloud → Secrets → VISIT_BRIDGE_TOKEN
VISIT_BRIDGE_TOKEN=invente_uma_palavra_secreta_longa

# ID no painel Admin → Demo visita
VISIT_OWNER_USER_ID=00000000-0000-0000-0000-000000000000
