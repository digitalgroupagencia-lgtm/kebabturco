# Configuração do Visit Print Bridge (Mac do admin master)
# Copie para: ~/.kebab-visit-print.env

SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=cole_a_service_role_key

# ID do seu utilizador admin master (copie do painel Admin → Demo visita)
VISIT_OWNER_USER_ID=00000000-0000-0000-0000-000000000000
